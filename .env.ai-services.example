# Copy to .env.ai-services or let the service setup generate it.
AI_API_KEY=replace-with-a-random-secret-at-least-32-characters
PA_CLIENT_TOKEN=replace-with-a-different-random-secret-at-least-32-characters
# Pairing is for the Windows client. Disable after setup if you want manual token-only access.
PAIRING_ENABLED=true
